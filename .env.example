# ═══════════════════════════════════════════════════════════
#  .env.example — Bu faylni GitHub'ga push qiling ✅
#  .env faylini HECH QACHON push qilmang ❌
# ═══════════════════════════════════════════════════════════
#
#  Ishlatish:
#  1. Bu faylni nusxalab ".env" deb nomlang
#  2. Qiymatlarni o'z kalitlaringiz bilan almashtiring
#  3. Netlify Dashboard > Site Settings > Environment Variables
#     ga ham shu qiymatlarni kiriting

# Supabase (supabase.com > Project Settings > API)
SUPA_URL=https://YOURPROJECT.supabase.co
SUPA_KEY=your_supabase_anon_key_here

# Telegram Bot (@BotFather dan oling)
TG_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TG_CHAT=123456789
